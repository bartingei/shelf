# Site URL (production domain) — used for canonical links, the sitemap, and
# Open Graph/Twitter tags. Set this to your real deployed domain in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (Neon)
# DATABASE_URL: pooled connection (hostname has "-pooler") — used by the app at runtime
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# DIRECT_URL: direct connection (no "-pooler") — used by Prisma migrations only
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (sends password reset emails) — get a key at resend.com
RESEND_API_KEY="re_..."

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# AI
OPENAI_API_KEY="sk-..."

# M-Pesa Daraja (production) — see docs/daraja-setup.md for exactly what to
# obtain from Safaricom before this can process a real transaction. The base
# URL is hardcoded to https://api.safaricom.co.ke in src/lib/daraja.ts —
# there is no sandbox fallback and no env var to switch it.
MPESA_CONSUMER_KEY="your-daraja-go-live-app-consumer-key"
MPESA_CONSUMER_SECRET="your-daraja-go-live-app-consumer-secret"
# Till number (Buy Goods) — used as both BusinessShortCode and PartyB in the
# STK push request, since TransactionType is CustomerBuyGoodsOnline.
MPESA_SHORTCODE="your-till-number"
# Lipa Na M-Pesa Online passkey, issued by Safaricom alongside your shortcode
# during the go-live process.
MPESA_PASSKEY="your-lnm-passkey"

# Cron
# Shared secret required in the Authorization: Bearer header for
# /api/cron/subscriptions. Vercel automatically sends this header when
# invoking the scheduled cron job if this env var is set on the project.
CRON_SECRET="generate-a-random-secret"
